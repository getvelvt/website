{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "velvt-web",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "velvt-waitlist",
      "database_id": "00000000-0000-0000-0000-000000000001"
    }
  ]
}
